APP_ENV=development
PORT=8000

# Agora ConvoAI Device Kit
# Get these from https://console.agora.io → Project Management → RESTful API
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
AGORA_CUSTOMER_ID=
AGORA_CUSTOMER_SECRET=

# Public URL for Agora tool-call webhook (run: ngrok http 8000)
WEBHOOK_BASE_URL=

# RTC channel — must match what R1 device is configured to join (default: pointdrop)
AGORA_CHANNEL=pointdrop
